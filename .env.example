# On-premises Jira Server / Data Center
JIRA_BASE_URL=https://jira.yourcompany.com
JIRA_TOKEN=your_jira_personal_access_token

# On-premises Bitbucket Server / Data Center (Stash)
BITBUCKET_BASE_URL=https://bitbucket.yourcompany.com
BITBUCKET_TOKEN=your_bitbucket_personal_access_token

# Tier 1: comma-separated PROJECT/repo pairs to scan for commits and PRs (fastest — no repo discovery)
# Format: PROJECTKEY/repo-slug  (find project key in Bitbucket → Project Settings → Details)
# Example: PROJ/backend-api,PROJ/frontend-app
BITBUCKET_PROJECTS=

# Tier 2: comma-separated project keys — lists all repos in each project, then filters by user activity
# Use when you want all repos under a project without pinning each one individually.
# Example: BITBUCKET_PROJECT_KEYS=PROJ,INFRA
# Leave blank if using BITBUCKET_PROJECTS (Tier 1) or auto-discovery (Tier 3).
BITBUCKET_PROJECT_KEYS=

# Jira pagination page size (200 or 500)
JIRA_PAGE_SIZE=500

# API authentication — all /api routes require this key in the X-Api-Key header
API_KEY=

# CORS — origin allowed to call the API (Vite dev default; set to your prod UI URL)
ALLOWED_ORIGIN=http://localhost:5173

# Bot user filter — regex applied to Bitbucket usernames to exclude bots from review metrics
BOT_USER_PATTERN=sonarqube|jenkins|deploymentbot|renovate|dependabot|buildbot|ci-bot

# Stale PR threshold — open PRs older than this many business days are flagged
STALE_PR_THRESHOLD_DAYS=3

# Server
PORT=3000

# ── Concurrency / performance tuning ─────────────────────────────────────────
# Max developers processed in parallel during a /metrics request.
# Lower this if the server is slow to start returning data.
METRICS_CONCURRENCY=3

# Max total simultaneous HTTP requests to Bitbucket/Jira across ALL operations.
# This is a global semaphore — the single most important knob for large loads.
# 9 users × 4 project keys can generate 500+ parallel requests without this limit.
# Start at 12 and increase only if the server handles it without dropping connections.
HTTP_CONCURRENCY=12

# Max concurrent repo-level API calls per developer (commits, PRs, activities).
# Multiplied by METRICS_CONCURRENCY for total repo fan-out per request.
REPO_CONCURRENCY=4

# Axios timeout per HTTP request in milliseconds (default 60s).
# Increase if Bitbucket is slow on large diff or activity endpoints.
HTTP_TIMEOUT_MS=60000

# ── JSON file cache ───────────────────────────────────────────────────────────
# Root directory for the local JSON cache. Relative paths are resolved from the
# project root. Mounted as a Docker volume in production (see docker-compose.yml).
CACHE_DIR=data/cache

# Months of cache to keep. Months older than this are deleted on startup.
# Increase for longer historical windows; decrease to save disk space.
CACHE_RETENTION_MONTHS=6

# ── AI Insights (optional) ────────────────────────────────────────────────────
# When enabled, the dashboard adds an AI-written narrative panel above the
# metrics widgets after every report run. Costs ~$0.01–0.03 per report.
# Set to false (default) to use the built-in rule-based summary at zero cost.
AI_INSIGHTS_ENABLED=false

# Which LLM provider to call: anthropic | openai | gemini
# anthropic → Claude Haiku  (~$0.01/report, fastest)
# openai    → GPT-4o mini   (~$0.01/report)
# gemini    → Gemini 2.0 Flash (~$0.005/report, cheapest)
AI_PROVIDER=anthropic

# API key for the provider chosen above. Only used when AI_INSIGHTS_ENABLED=true.
# Anthropic:  https://console.anthropic.com/settings/keys
# OpenAI:     https://platform.openai.com/api-keys
# Gemini:     https://aistudio.google.com/app/apikey
AI_API_KEY=

# Jira issue linking: connector (requires DVCS) | assignee | hybrid (default)
JIRA_ISSUE_LINKING_MODE=hybrid

# Persistent SQLite store for metrics cache and sync logs (survives restart)
APP_STORE_PATH=data/cache/app-store.sqlite

# SQLite metrics age expiry (ms). Default 0 = never expire by age. Set positive to re-enable TTL.
METRICS_SQLITE_TTL_MS=0

# ── Spec-driven metrics (optional) ───────────────────────────────────────────
# When enabled, each Jira issue is fetched with its full status-transition
# changelog to compute phased lead times and spec-waste signals.
# Adds one extra Jira API call per linked issue — disable on slow Jira servers.
SPEC_METRICS_ENABLED=false

# Jira status name that marks a specification as approved/locked.
# Must match your workflow status name exactly (case-insensitive).
SPEC_APPROVED_STATUS=Spec Approved

# Jira status name that marks the start of QA/verification against the spec.
SPEC_VERIFICATION_STATUS=Verification

# Jira status name that marks a ticket as fully done.
SPEC_DONE_STATUS=Done

# Jira status name that means the ticket is blocked or awaiting clarification.
SPEC_BLOCKED_STATUS=Blocked
